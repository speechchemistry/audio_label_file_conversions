  <TIME_ORDER />
  <TIER TIER_ID="Transcription" LINGUISTIC_TYPE_REF="Transcription" DEFAULT_LOCALE="ipa-ext" />
  <TIER TIER_ID="Phrase Free Translation" LINGUISTIC_TYPE_REF="Translation" PARENT_REF="Transcription" DEFAULT_LOCALE="ipa-ext" />
