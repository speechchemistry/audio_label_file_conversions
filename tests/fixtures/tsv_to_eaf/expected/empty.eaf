  <LOCALE LANGUAGE_CODE="ipa-ext" VARIANT="IPA Extended" />
  <CONSTRAINT STEREOTYPE="Time_Subdivision" DESCRIPTION="Time subdivision of parent annotation's time interval, no time gaps allowed within this interval" />
